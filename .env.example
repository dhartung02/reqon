# Job Pipeline CRM — environment variables.
# Copy this file to ".env" (same folder, next to server.js) and fill in values.
# The server loads .env automatically on boot; the scout (scout_run.py) inherits it.
# Anything already set in the real environment (e.g. the launchd plist) overrides .env.
# .env is gitignored — your key never gets committed.

# --- Deployment split (Render: api.reqon.app / cloud.reqon.app / reqon.app) ----
# REQON_ROLE selects what this process serves. Leave unset (= "all") for local dev / the
# single-box monolith. Set per Render service:
#   api    -> api.reqon.app   : backend + /health only; "/" returns JSON; the board UI is NOT served.
#   cloud  -> cloud.reqon.app : serves the board UI and reverse-proxies API paths to REQON_API_BASE_URL.
#   all    -> local default   : UI + API in one process (current behavior).
# REQON_ROLE=all
PORT=8787                          # Render injects this; the server already binds process.env.PORT.
# NODE_ENV=production              # set on Render; local can leave unset.
# REQON_API_BASE_URL=https://api.reqon.app    # REQUIRED in the cloud role — where the proxy forwards.
# REQON_CLOUD_BASE_URL=https://cloud.reqon.app # the product UI origin (used for links / CORS reference).
# REQON_PUBLIC_BASE_URL=https://reqon.app      # the marketing site origin (CTA target).
# CORS allowlist — origins that may make CREDENTIALED (cookie) calls to the API. Token-based capture
# tools (bookmarklet/extension, X-CRM-Token) keep working from any origin without credentials.
# CORS_ALLOWED_ORIGINS=https://cloud.reqon.app,https://reqon.app,http://localhost:8787,http://localhost:3000
# Persisted-data root. Local: leave unset (data lives in the repo). On an ephemeral host (Render),
# point this at a mounted disk so data.json, backups, profiles, settings, jobs, guides, and per-user
# namespaces survive deploys. Code/examples/python scripts always stay with the repo.
# REQON_DATA_DIR=/var/reqon-data

# --- OpenAI enrichment (OPTIONAL) ---------------------------------------------
# Set OPENAI_API_KEY to turn on AI rescoring during "Validate + refresh".
# Leave it blank/unset to stay deterministic-only (find + validate still work).
OPENAI_API_KEY=
# Set to whatever model your key can access (verify the exact name in your account).
OPENAI_MODEL=gpt-5.4-mini
# OPENAI_BASE_URL=https://api.openai.com/v1     # override for Azure/OpenAI-compatible proxy
# OPENAI_USE_CHAT=false        # true -> use legacy /chat/completions instead of the Responses API
# ASSIST_WEB_SEARCH=false      # true -> let drafts + interview guides use the web_search tool
#                                (current company context; adds cost — Responses API only)
# OPENAI_VECTOR_STORE_ID=      # a vector store id -> grounds drafts/guides on your résumé+narratives
#                                via file_search. Create one: python3 agent/setup-vector-store.py

# --- AI cost controls (optional; also settable in the Settings panel) ---------
# AI_ENRICH_MAX_PER_RUN=40    # max OpenAI calls per validate run (hard cap)
# AI_ENRICH_TTL_DAYS=14       # don't re-AI-score a role within this many days unless its JD changed
# OPENAI_JD_CHARS=3500        # how much of the job description to send (fewer chars = fewer tokens)
# OPENAI_MAX_TOKENS=400       # cap on response tokens per call

# --- AI application assistant (optional; also settable in the Settings panel) --
# ASSIST_ENABLED=true         # set false to disable the per-req draft assistant
# ASSIST_MODEL=gpt-5.4-mini   # assistant model (defaults to OPENAI_MODEL if unset)
# ASSIST_DAILY_CALLS=25       # hard cap on assistant calls per day
# ASSIST_MAX_TOKENS=700       # max tokens per generated draft
# GUIDE_MAX_TOKENS=1800       # max tokens for a (grounded-only) interview prep guide
# GUIDE_RESEARCH_MAX_TOKENS=2800  # max tokens for a "Research company" guide (uses web_search; pricier)
# OPENAI_TRANSCRIBE_MODEL=whisper-1  # speech-to-text model for the app's voice narratives
# TRANSCRIBE_MAX_MB=6         # reject audio clips larger than this (8mb JSON body limit caps it anyway)
# ASSIST_MONTHLY_TOKENS=0     # 0 = unlimited; rolling-30-day token ceiling (admin sets per user in
#                               multi-user via Settings → Admin → Caps; blocks AI calls once reached)
# --- AI consumption monitor (optional) — OpenAI can't report your balance via API, so set these
#     to estimate spend from logged tokens. Find your model's price at platform.openai.com/pricing.
# OPENAI_PRICE_PER_1M=        # USD per 1,000,000 tokens (blended) — enables $ estimates in the UI
# ASSIST_MONTHLY_BUDGET=      # your self-set monthly USD budget — drives the budget bar

# --- Morning digest (optional; also settable in the Settings panel) -----------
# DIGEST_ENABLED=false        # true to run the in-server scheduler
# DIGEST_TIME=07:00           # HH:MM, server local time
# DIGEST_CHANNEL=file         # legacy single channel | file | slack | email
# DIGEST_CHANNELS=file,inapp  # multi-channel: any of inapp,file,slack,email,sms,push (Settings UI)
# DIGEST_AFTER_SCOUT=false    # also send once after the first scout run of the day
# DIGEST_DAYS=1               # look-back window for "new finds"
# DIGEST_SLACK_WEBHOOK=       # Slack incoming-webhook URL (channel=slack)
# DIGEST_TO=                  # recipient(s), comma-separated (channel=email)
# DIGEST_FROM=                # From override (defaults to SMTP_USER)
# SMTP is the server's OUTBOUND identity — sends digests AND multi-user welcome emails. Use a
# dedicated sender, e.g. SMTP_USER=reqonapp@gmail.com + DIGEST_FROM=reqonapp@gmail.com (Gmail needs a
# 16-char App Password as SMTP_PASS). Each user receives at their own address (digest -> their email;
# welcome -> the email set on their account). Gmail INGEST (reading replies) stays per-user, separate.
# SMTP_HOST=                  # e.g. smtp.gmail.com   (channel=email)
# SMTP_PORT=587               # 587 STARTTLS, 465 implicit SSL
# SMTP_USER=                  # e.g. reqonapp@gmail.com
# SMTP_PASS=                  # app password
# --- SMS (optional; channel=sms) ----------------------------------------------
# SMS_METHOD=email            # email (free carrier gateway, uses SMTP) | twilio (paid)
# Free email-to-SMS gateway (SMS_METHOD=email) — reuses the SMTP config above:
# SMS_CARRIER=                # verizon|att|tmobile|sprint|uscellular|boost|cricket|metro|googlefi|visible
# SMS_GATEWAY_NUMBER=         # your mobile number, digits only e.g. 5551234567
# Twilio (SMS_METHOD=twilio; inert until all four are set):
# TWILIO_ACCOUNT_SID=         # from the Twilio console
# TWILIO_AUTH_TOKEN=          # secret
# TWILIO_FROM=                # your Twilio number, e.g. +15551234567
# SMS_TO=                     # your mobile, e.g. +15557654321
# --- Gmail per-event notifications (optional) ---------------------------------
# MAIL_NOTIFY_REJECTION=false # notify when ingest detects a rejection
# MAIL_NOTIFY_INTERVIEW=false # notify on interview
# MAIL_NOTIFY_OFFER=false     # notify on offer
# MAIL_NOTIFY_CHANNELS=inapp  # channels for the above (inapp,file,slack,email,sms,push)

# --- Gmail response ingest (optional; agent/mail_ingest.py) -------------------
# Reads application-response emails and reflects them on the board: auto-sets confident
# rejections, flags interview/offer for review. Use a Gmail APP PASSWORD (Google Account →
# Security → 2-Step Verification → App passwords), never your real password. Run
# `python3 agent/mail_ingest.py` (dry-run) first; `--apply` to act. Reuses DIGEST_SLACK_WEBHOOK
# for positive alerts, and OPENAI_API_KEY only when run with --ai.
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=        # 16-char app password (NOT your account password)
# GMAIL_LABEL=INBOX          # or a Gmail label/folder you file recruiter mail into
# MAIL_SINCE_DAYS=14         # look-back window per run
# MAIL_AI=false              # true -> AI-classify the keyword-ambiguous emails (uses OPENAI_API_KEY)

# --- Data safety (optional; also settable in the Settings panel) --------------
# BACKUP_RETENTION=50    # how many auto-snapshots (pre-save backups) to keep; older pruned
# PUT_GUARD_PCT=20       # refuse a full-array save that drops more than this % of rows
#                        # (0 disables the % guard; empty-over-non-empty is always refused;
#                        #  override per-save with ?allowShrink=1)

# --- Other optional settings --------------------------------------------------
# APP_TOKEN=your-passphrase        # require auth for /m, the board, and the API off-localhost
# PORT=8787
# SCOUT_PYTHON=/usr/bin/python3    # pin a python for the scout (else auto-detected)
# PUBLIC_URL=https://your-machine.tailnet.ts.net   # HTTPS origin baked into the pairing QR so the
#                                   # iOS app can connect off-LAN (iOS ATS blocks plaintext HTTP).
#                                   # Set to your Tailscale Funnel or Caddy hostname; blank = LAN only.
#                                   # `agent/run-tunnel.sh` sets this for you. Also editable in
#                                   # Settings → Advanced → Remote access URL.

# --- freemium tier / entitlements (optional) ----------------------------------
# Reqon ships a freemium model (core/entitlements.js): a FREE core, a CLOUD package
# (sync, digest/push delivery, Gmail ingest, scout, backups, pairing) and an AI package
# (drafts, auto-score, autofill, interview guides, follow-up suggestions).
#   - Self-hosted single-user (the default) is implicitly "Local Pro" — you own the box,
#     so EVERY feature is unlocked. You normally don't set anything here.
#   - REQON_LICENSE lets you DEMO a lower tier on your own box, or set the default grant
#     for hosted multi-user accounts. Values: "free" | "cloud" | "ai" | "cloud,ai" | "pro"
#     | "owner". In multi-user mode an admin can override per-account on the user record.
# REQON_LICENSE=free
# LOCAL_PRO=true                   # force the Local Pro (all-packages) unlock explicitly

# --- scoped capture token (WP: scoped auth) ---
# INGEST_TOKEN=long-random-string   # authorizes ONLY POST /api/reqs/merge + /api/reqs/quickadd
#                                   # (give this to capture automations, e.g. a ChatGPT Action)

# --- APNs push (WP-0: optional iOS push; inert unless ALL four are set) ---
# APNS_KEY_P8_PATH=secrets/AuthKey_XXXXXXXXXX.p8   # path relative to the project root
# APNS_KEY_ID=XXXXXXXXXX
# APNS_TEAM_ID=XXXXXXXXXX
# APNS_BUNDLE_ID=com.example.jobpipeline
# APNS_ENV=sandbox                  # or: production
