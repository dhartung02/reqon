{
  "manifest_version": 3,
  "name": "Reqon Clip",
  "version": "0.1.0",
  "description": "Clip job postings, see your fit/EV overlay on the page, and write Applied status back to your self-hosted Reqon pipeline. No autofill — that stays with your form-filler.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Clip this job to Reqon",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "background": { "service_worker": "bg.js" },
  "options_ui": { "page": "options.html", "open_in_tab": true },
  "permissions": ["storage", "activeTab", "alarms"],
  "host_permissions": ["http://localhost:8787/*"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "content_scripts": [
    {
      "matches": [
        "https://job-boards.greenhouse.io/*",
        "https://boards.greenhouse.io/*",
        "https://jobs.ashbyhq.com/*",
        "https://jobs.lever.co/*",
        "https://www.linkedin.com/jobs/*",
        "https://simplify.jobs/*"
      ],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ]
}
