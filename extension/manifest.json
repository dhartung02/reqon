{
  "manifest_version": 3,
  "name": "Reqon Clip",
  "version": "0.1.0",
  "description": "Clip job postings, see your fit/EV overlay, fill applications from your Reqon profile + saved answers, and write Applied status back to your self-hosted pipeline. Never submits.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Reqon Clip — status, clip, mark applied",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "background": { "service_worker": "bg.js" },
  "options_ui": { "page": "options.html", "open_in_tab": true },
  "side_panel": { "default_path": "sidepanel.html" },
  "permissions": ["storage", "activeTab", "alarms", "tabs", "notifications", "sidePanel"],
  "host_permissions": ["http://localhost:8787/*"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "content_scripts": [
    {
      "matches": [
        "https://job-boards.greenhouse.io/*",
        "https://boards.greenhouse.io/*",
        "https://jobs.ashbyhq.com/*",
        "https://jobs.lever.co/*",
        "https://www.linkedin.com/jobs/*",
        "https://simplify.jobs/*",
        "https://apply.workable.com/*",
        "https://*.workable.com/*",
        "https://jobs.smartrecruiters.com/*",
        "https://*.recruitee.com/*",
        "https://*.teamtailor.com/*",
        "https://*.jobs.personio.de/*",
        "https://*.jobs.personio.com/*"
      ],
      "js": ["lib.js", "content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ]
}
